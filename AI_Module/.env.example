# 必需
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# 可选：覆盖默认模型列表（逗号分隔，按优先级排序）
# 默认: anthropic/claude-sonnet-4.6,google/gemini-2.0-flash-001
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6,google/gemini-2.0-flash-001

# 可选：CORS 允许的域名（生产环境建议设置为你的网站域名）
# CORS_ORIGIN=https://your-site.com

# 可选：服务端口（默认 8000）
# PORT=8000
